{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "papers": {
      "type": "array",
      "description": "已验证的相关论文列表",
      "items": {
        "type": "object",
        "properties": {
          "arxiv_id": { "type": "string", "description": "arXiv ID，格式如 1512.03385" },
          "title": { "type": "string", "description": "论文标题" },
          "authors": { "type": "array", "items": { "type": "string" }, "description": "作者列表" },
          "abstract": { "type": "string", "description": "论文摘要" },
          "overview": { "type": "string", "description": "用中文写的2-3句话总结" },
          "published_at": { "type": "string", "description": "发表日期 YYYY-MM-DD" },
          "categories": { "type": "array", "items": { "type": "string" }, "description": "arXiv 分类" },
          "primary_class": { "type": "string", "description": "主分类，如 cs.CV" },
          "bibtex": { "type": "string", "description": "完整的 BibTeX 引用" },
          "abs_url": { "type": "string", "description": "arXiv 摘要页 URL" },
          "pdf_url": { "type": "string", "description": "arXiv PDF URL" },
          "relevance_score": { "type": "integer", "minimum": 1, "maximum": 5, "description": "1-5 相关性评分" }
        },
        "required": ["arxiv_id", "title", "authors", "abstract", "overview", "bibtex", "abs_url", "pdf_url", "relevance_score"]
      }
    },
    "summary": { "type": "string", "description": "本轮搜索的简短总结" },
    "search_queries_used": { "type": "array", "items": { "type": "string" }, "description": "实际使用的搜索词" }
  },
  "required": ["papers"]
}
