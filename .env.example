# DeepResearch 配置文件
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# [必填] DeepSeek API 密钥，用于生成 Claude Code worker 的搜索方向
DEEPSEEK_API_KEY=sk-your-key-here

# [可选] API 地址，默认 https://api.deepseek.com/v1
# 兼容任意 OpenAI 风格的接口，例如:
#   - DeepSeek: https://api.deepseek.com/v1
#   - OpenAI:   https://api.openai.com/v1
#   - 本地模型:  http://localhost:11434/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# [可选] 模型名称，默认 deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-pro

# [可选] 每次请求最大 token 数，默认 4096
DEEPSEEK_MAX_TOKENS=4096

# [可选] 是否启用 JSON Object 模式，默认 1
# 设为 0 可兼容不支持 response_format 的模型
DEEPSEEK_JSON_MODE=1

# [可选] 搜索后端，claude = Claude Code, arxiv = 直接 arXiv API fallback
SEARCH_BACKEND=claude

# [可选] 每次搜索超时秒数，默认 900（15 分钟）
SEARCH_TIMEOUT=900

# [可选] arXiv API 请求超时和重试次数
ARXIV_TIMEOUT=10
ARXIV_RETRIES=2

# [可选] HTTP 代理地址，用于访问被墙的服务（如 DuckDuckGo）
# 例如: http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
HTTP_PROXY=
