# DeepResearch 配置文件
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# [可选] OpenAI/DeepSeek 兼容 LLM 配置
# outline 命令（大纲生成）会使用这些配置调用 LLM。
# deepresearch 命令（文献搜集）的 Claude Code worker 不消费这些。
DEEPSEEK_API_KEY=sk-your-key-here

# [可选] API 地址
# 兼容任意 OpenAI 风格的接口，例如:
#   - DeepSeek: https://api.deepseek.com/v1
#   - OpenAI:   https://api.openai.com/v1
#   - 本地模型:  http://localhost:11434/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# [可选] 模型名称
DEEPSEEK_MODEL=deepseek-v4-flash

# [可选] 每次请求最大 token 数
DEEPSEEK_MAX_TOKENS=4096

# [可选] 是否启用 JSON Object 模式，默认 1
DEEPSEEK_JSON_MODE=1

# [可选] 每次搜索超时秒数，默认 900（15 分钟）
SEARCH_TIMEOUT=900

# [可选] Claude Code worker 使用的模型，留空则用 Claude Code 默认（当前为 Opus）
# 例如使用更便宜更快的 Haiku 4.5:
#   WORKER_MODEL=claude-haiku-4-5-20251001
WORKER_MODEL=

# [可选] PDF 下载相关
# PDF_MAX_ATTEMPTS: 单篇 PDF 最多尝试次数（含首次），默认 3
# PDF_RETRY_SLEEP: 失败重试时队列回退间隔秒数，默认 2.0
# PDF_TIMEOUT: PDF 下载请求超时秒数，默认 60
PDF_MAX_ATTEMPTS=3
PDF_RETRY_SLEEP=2.0
PDF_TIMEOUT=60

# [可选] HTTP 代理地址，用于访问被墙的服务（如 DuckDuckGo）
# 例如: http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
HTTP_PROXY=

# === Outline generator (LangGraph + LangChain) ===
# outline 命令复用上面的 DEEPSEEK_* 配置（LangChain ChatOpenAI 兼容）
# 可选：微调各节点的温度
# OUTLINE_TEMP_CLUSTER=0.1
# OUTLINE_TEMP_DRAFT=0.6
# OUTLINE_TEMP_MERGE=0.3
# OUTLINE_CLUSTER_MAX=6

# === Writer (Phase 3: 综述正文写作) ===
# write 命令使用 DeepSeek 并发写作 + FAISS RAG 验证
# 复用上方 DEEPSEEK_* 配置，无需额外服务

# [可选] HuggingFace 嵌入模型名称（CPU 友好）
EMBEDDING_MODEL=all-MiniLM-L6-v2

# [可选] 写作使用的 DeepSeek 模型，留空则复用 DEEPSEEK_MODEL
WRITER_MODEL=

# [可选] 写作超时秒数，默认 1800（30 分钟）
WRITE_TIMEOUT=1800

# [可选] 并发写作 worker 数，默认 4（受 DeepSeek API 速率限制）
WRITER_CONCURRENCY=4

# [可选] 每节最大写作重试次数（写作→验证→重写循环），默认 3
WRITER_MAX_RETRIES=3
