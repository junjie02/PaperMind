# PaperMind 配置文件
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# ── LLM 配置（OpenAI 兼容接口，当前使用 MiniMax）──────────────────────────
OPENAI_API_KEY=sk-your-key-here

# API 地址，兼容任意 OpenAI 风格接口:
#   MiniMax:  https://api.minimaxi.com/v1
#   DeepSeek: https://api.deepseek.com/v1
#   OpenAI:   https://api.openai.com/v1
OPENAI_BASE_URL=https://api.minimaxi.com/v1

# 模型名称
OPENAI_MODEL=MiniMax-M2.7

# 每次请求最大 token 数
OPENAI_MAX_TOKENS=4096

# ── 代理（DDG 搜索需要）────────────────────────────────────────────────────
HTTP_PROXY=http://10.122.195.110:7890
HTTPS_PROXY=http://10.122.195.110:7890

# ── RAG 嵌入模型 ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Sub-Agent 并发控制 ───────────────────────────────────────────────────────
MAX_CONCURRENT_AGENTS=4
AGENT_MAX_RETRIES=2

# ── Sub-Agent 超时（秒）─────────────────────────────────────────────────────
EXPLORER_TIMEOUT=600
RESEARCHER_TIMEOUT=900
WRITER_TIMEOUT=600
REVIEWER_TIMEOUT=300
POLISHER_TIMEOUT=300

# ── 终审 LLM 配置（可选，不填则使用主 LLM）──────────────────────────────────
# 用于最终全局审校，建议使用更强的模型（如 Claude、GPT-4o）
REVIEW_API_KEY=sk-your-review-key
REVIEW_BASE_URL=https://api.openai.com/v1
REVIEW_MODEL=gpt-4o
